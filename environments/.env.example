# Variables de entorno para el bot WhatsApp en n8n
# Copiar a .env.dev / .env.staging / .env.prod y completar.
# NUNCA commitear los archivos .env reales.

# --- Backend (sistema principal) ---
MAIN_API_BASE_URL=https://api.tuapp.com
MAIN_API_SERVICE_JWT=change_me_jwt
MAIN_API_TIMEOUT_MS=10000

# --- Proveedor WhatsApp (Evolution API de ejemplo) ---
EVOLUTION_API_BASE_URL=https://evolution.tuapp.com
EVOLUTION_API_KEY=change_me
WA_WEBHOOK_SECRET_EVOLUTION=change_me_hmac_secret

# --- Proveedor WhatsApp (Meta Cloud) ---
META_CLOUD_API_BASE_URL=https://graph.facebook.com/v20.0
META_CLOUD_ACCESS_TOKEN=change_me
WA_WEBHOOK_SECRET_META=change_me_hmac_secret

# --- Object storage (media) ---
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=wa-bot-media
S3_ACCESS_KEY=change_me
S3_SECRET_KEY=change_me
S3_REGION=us-east-1

# --- Alertas ---
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- Flags ---
ENV=dev
LOG_LEVEL=info
